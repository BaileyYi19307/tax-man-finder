# Copy this file to .env and adjust as needed:
#   cp .env.example .env

ENV=development
DEBUG=True
SECRET_KEY=django-insecure-change-me-for-local-dev

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://127.0.0.1:8000

#For WebSocket chat (Django Channels)
REDIS_URL=redis://127.0.0.1:6379/0

# Local/dev: print emails to the terminal instead of sending via SMTP
# For real email, set EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# and fill in the SMTP fields below.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# Only used when ENV=production. Leave blank for local SQLite
# DATABASE_URL is not read by settings.py today; use the DB_* vars below
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
